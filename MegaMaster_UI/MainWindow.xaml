<Window x:Class="MegaMaster_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MegaMaster_UI"
        mc:Ignorable="d"
        Title="Mastermind"
        Height="450"
        Width="600">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Naam speler:" FontWeight="Bold"/>

        <TextBox x:Name="txtPlayer"
                 Grid.Row="1"
                 Margin="0,5,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
            <ComboBox x:Name="cmb1" Width="100" Margin="5"/>
            <ComboBox x:Name="cmb2" Width="100" Margin="5"/>
            <ComboBox x:Name="cmb3" Width="100" Margin="5"/>
            <ComboBox x:Name="cmb4" Width="100" Margin="5"/>
        </StackPanel>

        <Button x:Name="BtnCheck"
                Grid.Row="3"
                Content="Controleer"
                Width="150"
                Height="35"
                Click="BtnCheck_Click"/>

        <ListBox x:Name="lstResults"
                 Grid.Row="4"
                 Margin="0,15,0,0"/>
    </Grid>
</Window>